<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="adorsys" id="add_end_of_day_permission_teller">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT count(*) FROM m_permission WHERE code = 'ENDOFDAYSETTLEMENT_TELLER'</sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="cash_mgmt"/>
            <column name="code" value="ENDOFDAYSETTLEMENT_TELLER"/>
            <column name="entity_name" value="TELLER"/>
            <column name="action_name" value="ENDOFDAYSETTLEMENT"/>
            <column name="can_maker_checker" valueNumeric="0"/>
        </insert>
    </changeSet>
</databaseChangeLog>
