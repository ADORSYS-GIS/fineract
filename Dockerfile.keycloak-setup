# Start with the Keycloak image
FROM quay.io/keycloak/keycloak:26.2.5

# Change to the root user to perform privileged operations
USER root

# Copy the setup script into the image
COPY setup_keycloak.sh /setup_keycloak.sh

# Make the script executable during the image build process
RUN chmod +x /setup_keycloak.sh

# Set the new entrypoint to run the script and then wait.
# This keeps the container alive so other services can depend on it.
ENTRYPOINT ["/bin/bash", "-c", "/setup_keycloak.sh && tail -f /dev/null"]
