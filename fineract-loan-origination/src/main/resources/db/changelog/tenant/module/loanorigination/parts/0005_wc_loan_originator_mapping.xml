<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <!-- Create m_wc_loan_originator_mapping table - MySQL -->
    <changeSet id="wc-loan-origination-001" author="fineract" context="mysql">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_originator_mapping"/>
            </not>
            <tableExists tableName="m_wc_loan"/>
        </preConditions>
        <createTable tableName="m_wc_loan_originator_mapping">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="originator_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create m_wc_loan_originator_mapping table - PostgreSQL -->
    <changeSet id="wc-loan-origination-002" author="fineract" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="m_wc_loan_originator_mapping"/>
            </not>
            <tableExists tableName="m_wc_loan"/>
        </preConditions>
        <createTable tableName="m_wc_loan_originator_mapping">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="originator_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add foreign keys for m_wc_loan_originator_mapping -->
    <changeSet id="wc-loan-origination-003" author="fineract">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_originator_mapping"/>
        </preConditions>
        <addForeignKeyConstraint baseTableName="m_wc_loan_originator_mapping" baseColumnNames="loan_id"
                                 referencedTableName="m_wc_loan" referencedColumnNames="id"
                                 constraintName="FK_wc_loan_originator_mapping_wc_loan" onDelete="RESTRICT" onUpdate="RESTRICT"/>
    </changeSet>

    <changeSet id="wc-loan-origination-004" author="fineract">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_originator_mapping"/>
        </preConditions>
        <addForeignKeyConstraint baseTableName="m_wc_loan_originator_mapping" baseColumnNames="originator_id"
                                 referencedTableName="m_loan_originator" referencedColumnNames="id"
                                 constraintName="FK_wc_loan_originator_mapping_originator" onDelete="RESTRICT" onUpdate="RESTRICT"/>
    </changeSet>

    <!-- Add FK for audit columns on m_wc_loan_originator_mapping -->
    <changeSet id="wc-loan-origination-005" author="fineract">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_originator_mapping"/>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_wc_loan_originator_mapping"
                                 constraintName="FK_wc_loan_originator_mapping_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT"
                                 referencedColumnNames="id" referencedTableName="m_appuser" validate="true"/>
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_wc_loan_originator_mapping"
                                 constraintName="FK_wc_loan_originator_mapping_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT"
                                 referencedColumnNames="id" referencedTableName="m_appuser" validate="true"/>
    </changeSet>

    <!-- Add unique constraint for wc-loan - originator mapping (prevent duplicate assignments) -->
    <changeSet id="wc-loan-origination-006" author="fineract">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_originator_mapping"/>
        </preConditions>
        <addUniqueConstraint tableName="m_wc_loan_originator_mapping" columnNames="loan_id, originator_id"
                             constraintName="UQ_wc_loan_originator_mapping_wc_loan_originator"/>
    </changeSet>

    <!-- Add indexes -->
    <changeSet id="wc-loan-origination-007" author="fineract">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_wc_loan_originator_mapping"/>
        </preConditions>
        <createIndex tableName="m_wc_loan_originator_mapping" indexName="idx_wc_loan_originator_mapping_originator">
            <column name="originator_id"/>
        </createIndex>
    </changeSet>

    <!-- Add permissions -->
    <changeSet id="wc-loan-origination-008" author="fineract">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(1) FROM m_permission WHERE code = 'ATTACH_WORKING_CAPITAL_LOAN_ORIGINATOR'</sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="ATTACH_WORKING_CAPITAL_LOAN_ORIGINATOR"/>
            <column name="entity_name" value="WORKING_CAPITAL_LOAN_ORIGINATOR"/>
            <column name="action_name" value="ATTACH"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet id="wc-loan-origination-009" author="fineract">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(1) FROM m_permission WHERE code = 'DETACH_WORKING_CAPITAL_LOAN_ORIGINATOR'</sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="DETACH_WORKING_CAPITAL_LOAN_ORIGINATOR"/>
            <column name="entity_name" value="WORKING_CAPITAL_LOAN_ORIGINATOR"/>
            <column name="action_name" value="DETACH"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
